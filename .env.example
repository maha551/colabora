# Colabora environment template
# Copy to .env and fill in values for local development or deployment.

# Server
NODE_ENV=development
PORT=3000

# Security (required in production; 32+ random characters)
JWT_SECRET=your-jwt-secret-here-at-least-32-characters-long
JWT_EXPIRES_IN=24h

# PostgreSQL (required)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/colabora_dev

# Connection pool (optional)
PG_POOL_MIN=2
PG_POOL_MAX=20

# Frontend / CORS
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email (optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=Colabora

# Legal / contact pages (optional)
CONTACT_EMAIL=
SITE_OPERATOR_NAME=
SITE_OPERATOR_ADDRESS=

# Redis (optional — multi-instance rate limiting / WebSocket adapter)
# REDIS_URL=redis://127.0.0.1:6379

# Admin bootstrap (first admin only, when no admin exists)
# ADMIN_BOOTSTRAP_EMAIL=admin@example.com
# ADMIN_BOOTSTRAP_PASSWORD=
