{
  "name": "colabora",
  "version": "1.0.0",
  "description": "Collaborative Drafting Software - Full Stack Application",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build": "npm run install:frontend && npm run build:frontend && npm run build:backend",
    "build:backend": "node --check server/index.js",
    "build:frontend": "cd client && npm run build",
    "install:frontend": "cd client && npm install",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:frontend\"",
    "dev:frontend": "cd client && npm run dev",
    "deploy:fly": "chmod +x deploy-fly.sh && ./deploy-fly.sh",
    "deploy:hetzner": "kamal deploy",
    "deploy:hetzner:pilot": "kamal deploy -d pilot",
    "deploy:hetzner:pilot:setup": "kamal setup -d pilot",
    "deploy:hetzner:staging": "kamal deploy -d staging",
    "deploy:hetzner:setup": "kamal setup",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageDirectory=coverage",
    "test:unit": "jest tests/unit --verbose",
    "test:client-unit": "jest --config jest.client-unit.config.js",
    "test:db:setup": "node scripts/setup-test-db.js",
    "pretest:integration": "node scripts/setup-test-db.js",
    "test:integration": "jest tests/integration --verbose",
    "test:e2e": "jest tests/e2e --verbose",
    "test:regression": "jest tests/regression --verbose",
    "test:websocket": "jest tests/websocket --verbose",
    "test:scheduler": "jest tests/scheduler --verbose",
    "test:middleware": "jest tests/middleware --verbose",
    "test:modules": "jest tests/modules --verbose",
    "test:all": "jest --coverage",
    "test:ci": "jest --coverage --ci",
    "test:quick": "jest tests/regression --maxWorkers=2",
    "test:security": "node scripts/security-test.js",
    "diagnose:db": "node scripts/diagnose-fly-database.js",
    "diagnose:db-server": "./scripts/diagnose-db-server-health.sh",
    "restart:db": "./scripts/restart-fly-db.sh",
    "check:db-setup": "./scripts/check-db-setup.sh",
    "restart:db-machine": "./scripts/restart-db-machine.sh",
    "check:db": "node scripts/check-database-connectivity.js",
    "test:security:remote": "node scripts/security-test.js --url",
    "test:smoke": "node scripts/smoke-test.js",
    "setup-admin": "node scripts/setup-admin.js",
    "setup-fly-secrets": "node scripts/setup-fly-secrets.js",
    "purge-database": "node scripts/purge-database.js",
    "clear-rate-limits": "node scripts/clear-rate-limits.js",
    "validate-env": "node scripts/validate-env.js",
    "test:email": "node scripts/test-email-setup.js",
    "security-check": "node scripts/security-test.js",
    "reset-deployed-db": "node reset-deployed-db.js",
    "deployment-check": "node scripts/deployment-check.js",
    "health-check": "node scripts/health-check.js",
    "monitor": "node scripts/monitor-deployment.js",
    "monitor:browser": "node scripts/monitor-browser-console.js",
    "clean:test-dbs": "node scripts/cleanup-test-dbs.js",
    "lint": "eslint server/**/*.js --fix || echo 'ESLint not configured'",
    "format": "prettier --write . || echo 'Prettier not configured'",
    "validate:design-system": "node scripts/validate-design-system.js",
    "verify:migration-order": "node scripts/verify-meetings-migration-order.js",
    "i18n:diff": "node scripts/diff-i18n-keys.js",
    "i18n:diff:es": "node scripts/diff-i18n-keys.js es",
    "i18n:diff:fr": "node scripts/diff-i18n-keys.js fr",
    "i18n:diff:rtl": "node scripts/diff-i18n-keys.js ar && node scripts/diff-i18n-keys.js fa && node scripts/diff-i18n-keys.js ur",
    "i18n:sync": "node scripts/sync-i18n-keys.js",
    "i18n:sync:rtl": "node scripts/sync-i18n-keys.js ar && node scripts/sync-i18n-keys.js fa && node scripts/sync-i18n-keys.js ur",
    "i18n:check-de": "node scripts/check-de-i18n.js",
    "i18n:check-fr": "node scripts/check-fr-i18n.js",
    "i18n:check-rtl": "node scripts/check-rtl-i18n.js",
    "i18n:convert-de-du": "node scripts/convert-de-du.js",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:migrate": "knex --knexfile knexfile.js migrate:latest",
    "db:rollback": "knex --knexfile knexfile.js migrate:rollback",
    "db:make": "knex --knexfile knexfile.js migrate:make",
    "db:reset": "knex --knexfile knexfile.js migrate:rollback --all && knex --knexfile knexfile.js migrate:latest",
    "build:docker": "docker build -t colabora .",
    "security:audit": "npm audit --audit-level=moderate --omit=dev",
    "security:scan": "npm audit --audit-level=high --json | jq '.vulnerabilities' || echo 'Security scan complete'"
  },
  "keywords": [
    "collaborative",
    "drafting",
    "document",
    "editing"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "node-fetch": "^2.7.0",
    "pdfkit": "^0.15.0",
    "pg": "^8.16.3",
    "resend": "^4.0.0",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "web-push": "^3.6.7",
    "winston": "^3.18.3",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "axios": "^1.13.2",
    "chai": "^6.2.0",
    "concurrently": "^8.2.2",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.3.0",
    "nodemon": "^3.0.2",
    "puppeteer": "^24.34.0",
    "sinon": "^21.0.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5"
  }
}
