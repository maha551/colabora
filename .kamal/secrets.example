# Copy to .kamal/secrets for local deploys (never commit .kamal/secrets).
# GitHub Actions: set each value as a repository secret (see docs/active/HETZNER_DEPLOYMENT.md).
#
# Pilot (10–50 users):
#   cp .kamal/secrets.example .kamal/secrets
#   kamal setup -d pilot && kamal deploy -d pilot
#
# Full walkthrough: docs/active/HETZNER_PILOT_CHECKLIST.md

# GHCR: GitHub PAT with read:packages + write:packages (or use GITHUB_TOKEN locally)
KAMAL_REGISTRY_PASSWORD=

# postgresql://colabora:PASSWORD@10.0.0.20:5432/colabora
DATABASE_URL=

# Recommended for pilot (rate limits + cache). Required when running 2+ app servers.
# redis://:PASSWORD@10.0.0.20:6379/0
REDIS_URL=

# openssl rand -hex 32
JWT_SECRET=

FRONTEND_URL=https://colabora.local-correspondent.com
ALLOWED_ORIGINS=https://colabora.local-correspondent.com

# Legal / public info pages (pilot test environment)
CONTACT_EMAIL=support@yourdomain.com
SITE_OPERATOR_NAME=Your Name or Organization
SITE_OPERATOR_ADDRESS=Street, City, Country

# Resend — required for org invites, password reset, notifications
# FROM address must be on the domain verified in https://resend.com/domains
# (verified local-correspondent.com → use noreply@local-correspondent.com, NOT @colabora.local-correspondent.com unless that subdomain is verified)
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=noreply@local-correspondent.com
