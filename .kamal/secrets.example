# Copy to .kamal/secrets for production deploy (never commit .kamal/secrets).
# Pilot overlay: cp to .kamal/secrets.pilot and use kamal deploy -d pilot
#
# Production (app-1 + data-1):
#   cp .kamal/secrets.example .kamal/secrets
#   kamal setup && kamal deploy

# GHCR: GitHub PAT with read:packages + write:packages (or use GITHUB_TOKEN locally)
KAMAL_REGISTRY_PASSWORD=

# data-1 on private network
DATABASE_URL=postgresql://colabora:PASSWORD@10.0.0.3:5432/colabora
REDIS_URL=redis://:PASSWORD@10.0.0.3:6379/0

JWT_SECRET=

FRONTEND_URL=https://colabora.local-correspondent.com
ALLOWED_ORIGINS=https://colabora.local-correspondent.com

CONTACT_EMAIL=colabora@local-correspondent.com
SITE_OPERATOR_NAME=colabora
SITE_OPERATOR_ADDRESS=Street, City, Country

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@local-correspondent.com
