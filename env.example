# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Server Configuration
NODE_ENV=development
PORT=3000

# Security Secrets (Generate secure random strings)
# In development, JWT_SECRET can be omitted and a random secret is generated.
# In production, JWT_SECRET is required and must be strong/non-placeholder.
JWT_SECRET=your-jwt-secret-here-at-least-32-characters-long
JWT_EXPIRES_IN=24h

# Database Configuration
# PostgreSQL only: use a postgres connection string in all environments.
# Required at runtime: server startup fails if DATABASE_URL is missing.
# Required format: must start with postgres:// or postgresql://.
# Local default when running `npm run db:up`:
# postgresql://postgres:postgres@localhost:5432/colabora_dev
# Production (Hetzner): dedicated Postgres on private network — see docs/active/HETZNER_DEPLOYMENT.md
# Migration workflow: `npm run db:make -- <name>` -> edit file in `knex/migrations` -> `npm run db:migrate`.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/colabora_dev

# PostgreSQL Connection Pool Configuration (only applies when using PostgreSQL)
# Set PG_POOL_MAX so that (number of app instances) * PG_POOL_MAX is below database max_connections (e.g. 80%).
# Run: node scripts/check-max-connections.js to see DB max_connections and current usage.
#
# Small (single instance, <50 users): PG_POOL_MIN=2, PG_POOL_MAX=10
# ~100 users, 2 app instances: PG_POOL_MIN=2, PG_POOL_MAX=40 per instance (total 80; DB max_connections > 90)
# 300 users, 3 instances: PG_POOL_MIN=5, PG_POOL_MAX=50 per instance; DB must allow ~160+ connections
#
PG_POOL_MIN=2
PG_POOL_MAX=10
# Timeout in milliseconds for acquiring a connection from the pool
PG_POOL_ACQUIRE_TIMEOUT=30000

# PostgreSQL Timeout Configuration (only applies when using PostgreSQL)
# Statement timeout in milliseconds (default: 300000 = 5 minutes)
PG_STATEMENT_TIMEOUT=300000
# Idle transaction timeout in milliseconds (default: 60000 = 60 seconds)
PG_IDLE_TRANSACTION_TIMEOUT=60000

# PostgreSQL TCP Keepalive Configuration (only applies when using PostgreSQL)
# Enable TCP keepalive to prevent connection termination (default: true)
PG_KEEPALIVE_ENABLED=true
# Initial delay in milliseconds before first keepalive probe (default: 30000 = 30 seconds)
# This is the time the connection must be idle before keepalive probes start
# Reduced from 60s to 30s to start probes sooner and prevent connection termination
PG_KEEPALIVE_INITIAL_DELAY=30000
# Socket timeout in milliseconds for total inactivity (default: 120000 = 2 minutes)
# If no data is sent/received for this duration, the socket will timeout
PG_SOCKET_TIMEOUT=120000

# CORS Configuration
FRONTEND_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001,https://yourdomain.com

# Email Configuration - Resend (https://resend.com)
# Production: RESEND_FROM_EMAIL must use an address on your *verified* domain in Resend
# (e.g. if you verified local-correspondent.com → noreply@local-correspondent.com)
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Colabora
# If RESEND_FROM_EMAIL is unset, Resend testing mode uses onboarding@resend.dev (your account email only)

# Web Push notifications (optional — generate VAPID keys: npx web-push generate-vapid-keys)
WEB_PUSH_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# Telegram notifications (optional — create bot via @BotFather)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# Production admin bootstrap (required only when no admin exists; none is auto-created)
# Explicit setup command: `npm run setup-admin`
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_TOKEN=

# Restore drill documentation location
# Keep operational restore drill notes at: docs/runbooks/db-restore-drill.md

# Logging
LOG_LEVEL=info
LOG_FILE=server.log

# Rate Limiting
# Optimized for 300 concurrent users: 1000 requests per 15 minutes
# This allows ~1.1 requests/second per user, reasonable for active discussion
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Redis Configuration (Optional but recommended for multi-instance deployments)
# Required for:
# 1. Shared rate limiting across multiple server instances
# 2. Socket.IO multi-instance WebSocket support
# If not set, rate limiting and WebSocket will work in single-instance mode only
# Format: redis://host:port or redis://:password@host:port
# REDIS_URL=redis://localhost:6379
# Hetzner production: Redis on data server (required with 2+ Kamal app servers)
# REDIS_URL=redis://:password@10.0.0.20:6379/0
# For Fly.io / Upstash (legacy):
# REDIS_URL=redis://default:password@your-redis-instance.upstash.io:6379

# --- Hetzner + Kamal (see docs/active/HETZNER_PILOT_CHECKLIST.md for pilot setup) ---
# Pilot: kamal deploy -d pilot  |  Production: kamal deploy
# FRONTEND_URL=https://colabora.example.com
# ALLOWED_ORIGINS=https://colabora.example.com
# PG_POOL_MIN=2          # pilot: 2 | production: 5
# PG_POOL_MAX=15         # pilot: 15 | production: 40
# VIDEO_PROVIDER=none
# JITSI_MEET_BASE_URL=https://meet.colabora.example.com

# File Upload (if needed)
MAX_FILE_SIZE=10485760

# Organization Debugging (development only)
# Enable detailed debugging queries and logs for organization loading
# WARNING: These significantly impact performance - only enable for debugging
ENABLE_ORG_DEBUG_QUERIES=false
ENABLE_ORG_DEBUG_LOGS=false
ENABLE_ORG_COUNT_VALIDATION=false

# Public site / legal pages
CONTACT_EMAIL=support@yourdomain.com
SITE_OPERATOR_NAME=
SITE_OPERATOR_ADDRESS=
TERMS_VERSION=2026-06-11
PRIVACY_VERSION=2026-06-11
# CONTACT_RATE_LIMIT_MAX=5

# Error Reporting (Vite - client-side)
# Set to true to hide the bug report button in the header (default: visible in dev and prod)
# VITE_DISABLE_ERROR_REPORTING=false