{
  "name": "colabora-app",
  "version": "1.0.0",
  "description": "Collaborative Drafting Software - Full Stack Application",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build": "npm run install:frontend && npm run build:frontend && npm run build:backend",
    "build:backend": "node --check server/index.js",
    "build:frontend": "cd client && npm run build",
    "install:frontend": "cd client && npm install",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:frontend\"",
    "dev:frontend": "cd client && npm run dev",
    "deploy:fly": "chmod +x deploy-fly.sh && ./deploy-fly.sh",
    "security-test": "node scripts/security-test.js",
    "security-test:remote": "node scripts/security-test.js --url"
  },
  "keywords": [
    "collaborative",
    "drafting",
    "document",
    "editing"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.17.3",
    "express-validator": "^7.3.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.1",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
