# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Server Configuration
NODE_ENV=development
PORT=3000

# Security Secrets (Generate secure random strings)
SESSION_SECRET=your-super-secure-random-session-secret-here-at-least-32-characters
JWT_SECRET=your-jwt-secret-here-at-least-32-characters-long
JWT_EXPIRES_IN=24h

# Database Configuration
DATABASE_URL=sqlite:///data/colabora.db
# For PostgreSQL in production: postgresql://username:password@host:port/database

# CORS Configuration
FRONTEND_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3001,https://yourdomain.com

# Email Configuration (for future password reset, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Logging
LOG_LEVEL=info
LOG_FILE=server.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload (if needed)
MAX_FILE_SIZE=10485760
